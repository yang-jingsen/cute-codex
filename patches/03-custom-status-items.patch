+        let short_timeout = std::time::Duration::from_secs(
+            self.config.notify_service.notify_service_idle_timeout_secs,
+        );
+        let entered_at = self.idle_entered_at?;
+        let status = self.idle_notification_status.clone()?;
+        let elapsed = now.checked_duration_since(entered_at)?;
+        if !matches!(
+            status,
+            crate::notify_service::IdleNotifyStatus::TaskCompleted
+        ) {
+            if elapsed >= short_timeout {
+                return Some((status, elapsed.as_secs()));
+            }
+            return None;
+        }
+
+        let composer_changed = self
+            .idle_composer_activity_generation
+            .is_some_and(|generation| {
+                generation != self.bottom_pane.composer_activity_generation()
+            })
+            || self.external_editor_state != ExternalEditorState::Closed;
+        if !composer_changed {
+            if elapsed >= short_timeout {
+                return Some((status, elapsed.as_secs()));
+            }
+            return None;
+        }
+
+        let long_timeout = std::time::Duration::from_secs(
+            self.config
+                .notify_service
+                .notify_service_composer_idle_timeout_secs,
+        );
+        let composer_idle_started_at = self
+            .bottom_pane
