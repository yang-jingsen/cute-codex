+    fn fire_idle_notification(
+        &mut self,
+        status: crate::notify_service::IdleNotifyStatus,
+        idle_seconds: u64,
+    ) {
+        let ns = &self.config.notify_service;
+        let Some(url) = ns.notify_service_url.as_ref().filter(|u| !u.is_empty()) else {
+            return;
+        };
+        let cwd = self
