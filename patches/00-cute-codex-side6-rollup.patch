+const PROTOCOL_ENV_VALUE: &str = "osc777";
+const SCHEMA: &str = "cutecharm-cutex.terminal.v1";
+const SOURCE: &str = "cute-codex";
+const OSC_PREFIX: &str = "\x1b]777;cutecharm-cutex;";
