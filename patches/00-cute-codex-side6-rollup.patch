+#[derive(serde::Deserialize)]
+struct CutexAgentSendArgsForUi {
+    to: String,
+    message: String,
+}
+
+#[derive(serde::Deserialize)]
+struct CutexAgentSendOutputForUi {
+    #[serde(default)]
+    ok: Option<bool>,
+    #[serde(default)]
+    message_id: Option<String>,
+    #[serde(default)]
+    from: Option<String>,
+    #[serde(default)]
+    to: Option<String>,
+    #[serde(default)]
+    to_name: Option<String>,
+    #[serde(default)]
+    queued: Option<bool>,
+    #[serde(default)]
+    trigger_turn: Option<bool>,
+    #[serde(default)]
+    deduplicated: Option<bool>,
 }
