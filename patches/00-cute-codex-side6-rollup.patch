+#[async_trait::async_trait]
+impl ToolExecutor<ToolInvocation> for CutexAgentListHandler {
+    fn tool_name(&self) -> ToolName {
+        ToolName::plain(CUTEX_AGENT_LIST_TOOL_NAME)
