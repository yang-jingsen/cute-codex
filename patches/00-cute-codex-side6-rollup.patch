+    }
+    assert!(!force_http_transport_enabled());
+
+    unsafe {
+        std::env::remove_var(key);
+    }
+    assert!(!force_http_transport_enabled());
+
+    match old {
+        Some(value) => unsafe { std::env::set_var(key, value) },
