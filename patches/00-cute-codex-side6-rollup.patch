+        "preview" => Some(NotifyServiceUserMessageContent::Preview),
+        "full" => Some(NotifyServiceUserMessageContent::Full),
+        "" => None,
+        other => {
+            tracing::warn!(
+                mode = other,
+                "ignoring unknown CODEX_NOTIFY_USER_MESSAGE_CONTENT value"
+            );
+            None
+        }
+    }
+}
