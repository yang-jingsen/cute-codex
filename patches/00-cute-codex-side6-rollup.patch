+    pub(super) fn emit_completed_notification_for_thread_item(&self, item: &ThreadItem) {
+        match item {
+            ThreadItem::CommandExecution {
+                id,
+                cwd,
+                process_id,
+                source,
+                command_actions,
+                exit_code,
+                duration_ms,
+                ..
+            } => {
