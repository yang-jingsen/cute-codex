+    let entered_at = Instant::now();
+    enter_task_completed_idle(&mut chat, entered_at);
+
+    assert_eq!(
+        chat.idle_notification_due_at(entered_at + Duration::from_secs(60)),
+        Some((crate::notify_service::IdleNotifyStatus::TaskCompleted, 60))
+    );
+}
